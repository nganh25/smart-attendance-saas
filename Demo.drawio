    <mxCell id="IZY_Q4YNWJR29QdOZAtN-964" parent="IZY_Q4YNWJR29QdOZAtN-623" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#232F3E;fillColor=#F5F5F5;strokeColor=#CCCCCC;rounded=1;arcSize=8;spacing=8;" value="&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;b&gt;Process Flow Legend&lt;/b&gt;&lt;br&gt;&lt;div&gt;&lt;b&gt;1&lt;/b&gt; DNS Request ↔ Route 53&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;2&lt;/b&gt; HTTPS Request → CloudFront (Protected by WAF + Shield)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;3&lt;/b&gt; Static Content Delivery ← Amazon S3 (React SPA)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;4&lt;/b&gt; Authentication (Web/Mobile) ↔ Amazon Cognito&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;4a&lt;/b&gt; API Proxy Path (Custom Header Verify) → CloudFront → API Gateway&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;5&lt;/b&gt; Authorized Request (with JWT) → CloudFront&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;6&lt;/b&gt; Synchronous API Triggers → Lambda Functions&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;7&lt;/b&gt; Asynchronous Report Request → SQS Queue (Independent Layer)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;8a&lt;/b&gt; CDC Capture → DynamoDB Streams&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;8b&lt;/b&gt; CDC Events → DynamoDB Streams → EventBridge&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;9&lt;/b&gt; Workflow Complete Events → Step Functions → EventBridge&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;10&lt;/b&gt; Transactional Data Ops ↔ DynamoDB (Single-Table Design)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;11&lt;/b&gt; Report File Storage → Amazon S3 (Intelligent-Tiering)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;12&lt;/b&gt; Notification Routing → SQS Email Queue + DLQ&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;13&lt;/b&gt; Batch Processing → Lambda Email Worker&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;14&lt;/b&gt; Secured Email Delivery → Amazon SES&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;15&lt;/b&gt; Outbound Webhook Alerts → External Systems&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;16&lt;/b&gt; B2B Subscription Billing → Payment Gateway&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;16a&lt;/b&gt; Inbound Payment Webhook → API Gateway → Lambda Webhook&lt;/div&gt;&lt;/font&gt;" vertex="1">
      <mxGeometry height="720" width="290" x="1320" y="40" as="geometry" />
    </mxCell>
