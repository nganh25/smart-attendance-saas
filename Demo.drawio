    <mxCell id="MOBILE_API_EDGE_LABEL" connectable="0" parent="MOBILE_API_EDGE" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontStyle=1;fontSize=12;" value="5" vertex="1">
